{
  "name": "web-runner",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --build && pnpm --filter @web-runner/web check",
    "build": "pnpm -r build",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-svelte": "^3.1.0",
    "globals": "^16.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=23",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msgpackr-extract"]
  }
}
